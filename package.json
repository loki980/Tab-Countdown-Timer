{
  "name": "tab-countdown-timer",
  "version": "1.0.0",
  "description": "A browser extension for Chrome and Edge that allows you to set a countdown timer for any tab. When the timer reaches zero, the tab automatically closes. Perfect for time management, limiting time spent on specific websites, or setting reminders.",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate": "node scripts/validate-manifest.js",
    "build": "node scripts/build-extension.js",
    "security-audit": "npm audit --omit=dev --audit-level=moderate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loki980/Tab-Countdown-Timer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/loki980/Tab-Countdown-Timer/issues"
  },
  "homepage": "https://github.com/loki980/Tab-Countdown-Timer#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "npm-check-updates": "^22.1.0"
  }
}
